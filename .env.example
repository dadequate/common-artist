# CommonArtist — environment configuration
# Copy to .env and fill in your values

# App
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://commonartist:commonartist@db:5432/commonartist

# Email (pick one: smtp or brevo or resend)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=gallery@example.com

# ── POS Integration ──────────────────────────────────────────────────────────
# Options: shopify | manual
# Default: manual (no API needed — sales entered through admin UI)
POS_PROVIDER=manual

# Shopify (required when POS_PROVIDER=shopify)
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ADMIN_API_KEY=
SHOPIFY_WEBHOOK_SECRET=

# Square (Phase 4 — not yet implemented)
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_WEBHOOK_SIGNATURE_KEY=

# ── Payment Integration ───────────────────────────────────────────────────────
# Options: check | stripe
# Default: check (manager issues physical checks; no Stripe account needed)
PAYMENT_PROVIDER=check

# Stripe Connect (required when PAYMENT_PROVIDER=stripe — Phase 3+)
# Do not configure until v0.1 payout logic is proven through one real cycle.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# ── Accounting Integration ────────────────────────────────────────────────────
# Options: none | qbo | xero
# Default: none (no accounting sync)
ACCOUNTING_PROVIDER=none

# QuickBooks Online (Phase 3)
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REFRESH_TOKEN=
# QBO_REALM_ID=

# Xero (Phase 3)
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_TENANT_ID=

# ── Monitor ───────────────────────────────────────────────────────────────────
MONITOR_ALERT_EMAIL=
MONITOR_SLACK_WEBHOOK=
