# CommonArtist — environment configuration
# Copy to .env and fill in your values

# App
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://commonartist:commonartist@db:5432/commonartist

# Email (pick one: SMTP or Brevo/Resend API)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=gallery@example.com

# Shopify (optional — for POS sync)
SHOPIFY_STORE=
SHOPIFY_ADMIN_API_KEY=

# Stripe (optional — for ACH payouts)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Monitor
MONITOR_ALERT_EMAIL=
MONITOR_SLACK_WEBHOOK=
